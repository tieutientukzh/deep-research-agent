# =============================================================
# Deep Research Agent — environment variables
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` (it is git-ignored).
# =============================================================

# ===== LLM provider (REQUIRED) =====
# Which provider to talk to: "gemini" or "groq".
# Both are reached through their OpenAI-compatible endpoint, so only the key,
# base URL and model names differ — see src/deep_research_agent/core/llm_client.py.
LLM_PROVIDER=gemini

# ----- Google Gemini -----
# Free tier has no hard tokens-per-day cap (unlike Groq), which suits the
# token-hungry deep pipeline. Only Flash/Flash-Lite are free; Pro needs billing.
GEMINI_API_KEY=your_gemini_api_key_here
# Fast/cheap model for planning & search-query generation:
GEMINI_MODEL_FAST=gemini-flash-lite-latest
# Strong model for research decisions & report writing:
GEMINI_MODEL_STRONG=gemini-flash-latest

# ----- Groq (kept as a fallback / comparison baseline) -----
# NOTE: free tier is capped at ~100K tokens/day on llama-3.3-70b — one deep run
# can exhaust it. Fine for `--mode simple`.
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_STRONG=llama-3.3-70b-versatile

# ===== Web search: Tavily (REQUIRED) =====
TAVILY_API_KEY=your_tavily_api_key_here

# ===== Web search fallbacks (OPTIONAL) =====
# SERPER_API_KEY=your_serper_api_key_here
# BRAVE_API_KEY=your_brave_api_key_here

# ===== Observability: Langfuse (OPTIONAL) =====
# LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
# LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx
# LANGFUSE_HOST=https://cloud.langfuse.com

# ===== App config (OPTIONAL) =====
# Path to the SQLite DB that stores runs + cache:
# DB_PATH=./data/research.db
# LOG_LEVEL=INFO
